    dealerFight:false, secretCount:0, legendSaved:false,
    lastItemEarned:null, currentEnemy:null
  };
  goMap();
}

/* ============================================================
   BARALHO
   ============================================================ */
function buildDeck(){
  let d = [];
  for(let s of SUITS) for(let v of VALS) d.push({v, s});
  for(let i = d.length-1; i>0; i--){
    const j = Math.floor(Math.random()*(i+1));
    [d[i], d[j]] = [d[j], d[i]];
  }
  return d;
}
function cv(v){ if(['J','Q','K'].includes(v)) return 10; if(v==='A') return 11; return parseInt(v); }
function hv(h){ let t=0,a=0; for(let c of h){ t+=cv(c.v); if(c.v==='A') a++; } while(t>21&&a>0){ t-=10; a--; } return t; }
function drawCard(){ if(G.deck.length<10) G.deck=buildDeck(); return G.deck.pop(); }

/* ============================================================
   RENDER CARTAS
   ============================================================ */
function renderCards(id, hand, hide){
  const el = document.getElementById(id);
  el.innerHTML = '';
  hand.forEach((c, i) => {
    const d = document.createElement('div');
    if(hide && i===1){ d.className='card hid'; }
    else { d.className='card'+(RED.includes(c.s)?' r':''); d.innerHTML=`<div class="ss">${c.s}</div><div class="sv">${c.v}</div>`; }
    el.appendChild(d);
  });
}

/* ============================================================
   HUD
   ============================================================ */
function updScore(v, id){
  const el = document.getElementById(id);
  el.textContent = v;
  el.className = 'sc-num';
  if(v > 21) el.classList.add('sc-bust');
  else if(v === 21) el.classList.add('sc-bj');
}
function updHud(){ document.getElementById('hudHand').textContent = G.curHand+'/'+G.totalHands; }
function updPsy(){ document.getElementById('hudPFill').style.width = Math.round(G.psy)+'%'; }
function updSpec(){
  document.getElementById('spFill').style.width = Math.round(G.spec)+'%';
  document.getElementById('spVal').textContent = Math.round(G.spec)+'%';
}
function showCtrl(h, s, d){
  document.getElementById('bH').disabled = !h;
  document.getElementById('bS').disabled = !s;
  document.getElementById('bD').style.display = d ? 'inline-block' : 'none';
  document.getElementById('bH').style.display = !d ? 'inline-block' : 'none';
  document.getElementById('bS').style.display = !d ? 'inline-block' : 'none';
  const hasUsable = G.inventory.length>0 && !G.usedItem;
  document.getElementById('bItem').style.display = (h && hasUsable) ? 'inline-block' : 'none';
}
function setMsg(tx, cl){
  const el = document.getElementById('rMsg');
  el.textContent = tx||'';
  el.className = 'rm '+(cl||'');
}

/* ============================================================
   MAPA
   ============================================================ */
function goMap(){
  G.phase = 'map';
  renderMap();
  show('sM');
}

function renderTit(){
  const si = document.getElementById('tSavedInfo');
  si.textContent = (G.savedRoutes && Object.keys(G.savedRoutes).length>0)
    ? 'Jornada anterior registrada no Livro de Memórias' : '';
}

function renderMap(){
  const isDealer = G.curEnemy >= G.enemies.length;
  const cur = isDealer ? DEALER : ENEMIES[G.curEnemy];
  document.getElementById('mTitle').textContent = G.campaignDone
    ? 'Campanha concluída — rotas reveladas'
    : 'Mapa — cinza enquanto a jornada continua';

  const track = document.getElementById('mTrack');
  track.innerHTML = '';

  ENEMIES.forEach((e, i) => {
    if(i > 0){ const ln=document.createElement('div'); ln.className='m-ln'; ln.style.background=i<=G.curEnemy?e.col+'44':'#1e1828'; track.appendChild(ln); }
    const nd = document.createElement('div');
    nd.className = 'm-nd '+(i<G.curEnemy?'done':i===G.curEnemy&&!isDealer?'cur':'lock');
    nd.style.borderColor = i<G.curEnemy?e.col+'44':i===G.curEnemy&&!isDealer?e.col:'#1e1828';
    nd.innerHTML = `<div class="m-icon" style="color:${i<G.curEnemy?e.col+'88':i===G.curEnemy&&!isDealer?e.col:'#3a2a4a'}">${i<G.curEnemy?'✓':e.icon}</div><div class="m-lbl" style="color:${i<=G.curEnemy?e.col+'88':'#2a1a3a'}">${e.name}</div>`;
    track.appendChild(nd);
  });

  const dln = document.createElement('div'); dln.className='m-ln'; dln.style.background=isDealer?DEALER.col+'44':'#1e1828'; track.appendChild(dln);
  const dnd = document.createElement('div');
  dnd.className = 'm-nd '+(isDealer?'cur':'lock');
  dnd.style.borderColor = isDealer?DEALER.col:'#1e1828';
  dnd.innerHTML = `<div class="m-icon" style="color:${isDealer?DEALER.col:'#3a2a4a'}">${DEALER.icon}</div><div class="m-lbl" style="color:${isDealer?DEALER.col+'88':'#2a1a3a'}">Dealer</div>`;
  track.appendChild(dnd);

  document.getElementById('mcName').textContent = cur.name;
  document.getElementById('mcSub').textContent = cur.sub;
  document.getElementById('mcBio').textContent = cur.bio;

  const rs = document.getElementById('mcRoutes');
  if(G.curEnemy > 0){
    rs.innerHTML = `
      <div class="m-rs"><div class="m-rs-n" style="color:#4a8a5a">${G.globalRoute.g}</div><div style="font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#2a4a2a">Redenção</div></div>
      <div class="m-rs"><div class="m-rs-n" style="color:#8a2020">${G.globalRoute.b}</div><div style="font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#4a1a1a">Corrupção</div></div>
      <div class="m-rs"><div class="m-rs-n" style="color:#6a3a8a">${G.globalRoute.s}</div><div style="font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#3a1a5a">Segredo</div></div>`;
  } else { rs.innerHTML=''; }

  const ie = document.getElementById('mItemEarned');
  if(G.lastItemEarned){ ie.style.display='block'; ie.innerHTML=`Item obtido: <strong style="color:#c9a84c">${G.lastItemEarned}</strong>`; ie.style.color='#8a7a5a'; G.lastItemEarned=null; }
  else { ie.style.display='none'; }
}

/* ============================================================
   LOJA
   ============================================================ */
function goShop(){
  const gRouteKey = G.globalRoute.s>=2?'secret':G.globalRoute.g>G.globalRoute.b?'good':G.globalRoute.b>G.globalRoute.g?'bad':'neutral';
  document.getElementById('shVendorTxt').textContent = VENDOR_TEXTS[gRouteKey]||VENDOR_TEXTS.neutral;
  document.getElementById('shGold').textContent = G.gold;
  const grid = document.getElementById('shGrid');
  grid.innerHTML = '';
  SHOP_ITEMS.forEach(it => {
    const owned = G.inventory.includes(it.id);
    const div = document.createElement('div');
    div.className = 'sh-item'+(owned?' owned':'');
    div.style.borderColor = owned?'#3a5a2a':'#2a2418';
    div.innerHTML = `<div class="sh-irare" style="color:${it.col}">${it.rare}</div><div class="sh-iname" style="color:#c9a84c">${it.name}</div><div class="sh-idesc" style="color:#6a5a3a">${it.desc}</div><div class="sh-iprice" style="color:${owned?'#3a5a2a':G.gold>=it.price?'#c9a84c':'#5a3a2a'}">${owned?'Adquirido':'Fichas: '+it.price}</div>`;
    if(!owned) div.onclick = ()=>buyItem(it);
    grid.appendChild(div);
  });
  show('sSh');
}

function buyItem(it){
  if(G.gold < it.price) return;
  G.gold -= it.price;
  G.inventory.push(it.id);
  document.getElementById('shGold').textContent = G.gold;
  goShop();
}

/* ============================================================
   BATALHA — SETUP
   ============================================================ */
function startBattle(){
  const isDealer = G.curEnemy >= G.enemies.length;
  const en = isDealer ? DEALER : ENEMIES[G.curEnemy];
  G.phase='battle'; G.deck=buildDeck();
  G.pH=[]; G.eH=[]; G.pSc=0; G.eSc=0;
  G.curHand=1; G.totalHands=en.totalHands||6; G.handsDone=0; G.wins=0;
  G.dlgIdx=0; G.route={g:0,b:0,s:0}; G.psy=70; G.spec=50;
  G.usedItem=false; G.legendSaved=false; G.currentEnemy=en;

  document.getElementById('hudPort').textContent = en.icon;
  document.getElementById('hudPort').style.color = en.col;
  document.getElementById('hudPort').style.borderColor = en.col+'44';
  document.getElementById('hudName').textContent = en.name;
  document.getElementById('hudName').style.color = en.col;
  document.getElementById('hudSub').textContent = en.sub;
  document.getElementById('tblELbl').textContent = en.name;
  document.getElementById('hudPFill').style.background = en.col;
  document.getElementById('specBar').style.display = 'flex';
  document.getElementById('spLbl').textContent = en.spec||en.barLbl||'Estado';
  document.getElementById('spFill').style.background = en.barCol||'#6a2a8a';

  updHud(); updPsy(); updSpec();
  document.getElementById('dlgArea').style.display='none';
  document.getElementById('chArea').style.display='none';
  show('sG');
  deal();
}

/* ============================================================
   BLACKJACK — MECÂNICA
   ============================================================ */
function deal(){
  if(G.handsDone >= G.totalHands) return;
  if(G.deck.length < 10) G.deck = buildDeck();
  G.pH=[drawCard(),drawCard()]; G.eH=[drawCard(),drawCard()];
  G.pSc=hv(G.pH); G.eSc=hv(G.eH); G.phase='player'; G.usedItem=false;
  const hasPeek = G.inventory.includes('peek');
  renderCards('pCards',G.pH,false);
  renderCards('eCards',G.eH,!hasPeek);
  updScore(G.pSc,'pScore');
  showCtrl(true,true,false); setMsg();
  document.getElementById('dlgArea').style.display='none';
  document.getElementById('chArea').style.display='none';
}

function hit(){
  if(G.phase!=='player') return;
  const c = drawCard(); G.pH.push(c); G.pSc=hv(G.pH);
  renderCards('pCards',G.pH,false); updScore(G.pSc,'pScore');
  G.spec = Math.min(100, G.spec+3); updSpec();
  if(G.pSc > 21){
    if(G.inventory.includes('shield') && !G.usedItem){
      G.usedItem=true; G.pSc=21; G.pH[G.pH.length-1]={v:'?',s:'♥'};
      renderCards('pCards',G.pH,false); updScore(G.pSc,'pScore'); setMsg('Escudo ativou!','rd'); return;
    }
    endHand();
  } else if(G.pSc===21){ stand(); }
}

function stand(){
  if(G.phase!=='player') return;
  G.phase='enemy';
  if(G.inventory.includes('mirror') && !G.usedItem){ G.usedItem=true; G.pSc=G.eSc; updScore(G.pSc,'pScore'); setMsg('Espelho ativado','rd'); }
  if(G.inventory.includes('anchor') && !G.usedItem){ G.usedItem=true; while(G.eSc<17){ G.eH.push(drawCard()); G.eSc=hv(G.eH); } if(G.eSc>17) G.eSc=17; }
  else { while(G.eSc<17){ G.eH.push(drawCard()); G.eSc=hv(G.eH); } }
  renderCards('eCards',G.eH,false);
  endHand();
}

function useItem(){
  if(G.inventory.length===0 || G.usedItem) return;
  const it = G.inventory[0];
  if(it==='echo'){
    G.usedItem=true;
    const best = Math.max(...G.pH.map(c=>cv(c.v)));
    setMsg('Eco: +'+Math.floor(best/3),'rd');
    G.pSc=Math.min(21,G.pSc+Math.floor(best/3));
    updScore(G.pSc,'pScore');
  } else if(it==='legend'){
    G.usedItem=true; G.legendSaved=true; setMsg('Ficha dourada ativa','rd');
  }
  showCtrl(true,true,false);
}

function endHand(){
  G.handsDone++; G.curHand=Math.min(G.handsDone+1,G.totalHands); updHud();
  let msg='',mc=''; const ps=G.pSc, es=G.eSc; let win=false;
  if(ps>21){ msg='Estourou!'; mc='rl'; G.psy=Math.max(0,G.psy-12); G.spec=Math.min(100,G.spec+8); }
  else if(es>21||ps>es){ win=true; msg='Você venceu'; mc='rw'; G.wins++; G.psy=Math.min(100,G.psy+5); G.spec=Math.max(0,G.spec-5); }
  else if(ps===es){ msg='Empate'; mc='rd'; }
  else { msg='Inimigo venceu'; mc='rl'; G.psy=Math.max(0,G.psy-8); G.spec=Math.min(100,G.spec+8); }
  if(G.legendSaved && !win){ G.legendSaved=false; win=true; msg='Ficha dourada salvou!'; mc='rw'; G.wins++; G.inventory=G.inventory.filter(i=>i!=='legend'); }
  updPsy(); updSpec(); setMsg(msg,mc);
  const dlgs = G.currentEnemy.dlg||[];
  const di = dlgs.findIndex(d=>d.h===G.handsDone);
  if(di!==-1 && G.dlgIdx<=di){ G.dlgIdx=di+1; showCtrl(false,false,false); setTimeout(()=>showDlg(dlgs[di]),800); }
  else if(G.handsDone>=G.totalHands){ showCtrl(false,false,false); setTimeout(endBattle,1200); }
  else { showCtrl(false,false,true); }
}

/* ============================================================
   DIÁLOGOS E ESCOLHAS
   ============================================================ */
function showDlg(d){
  document.getElementById('dlgArea').style.display='block';
  document.getElementById('dlgSp').textContent = G.currentEnemy.name;
  document.getElementById('dlgTx').textContent = d.tx;
  document.getElementById('chArea').style.display='block';
  const g=document.getElementById('chGrid'); g.innerHTML='';
  d.ch.forEach(c=>{
    const b=document.createElement('button');
    b.className='ch-btn '+c.tp; b.textContent=c.t;
    b.onclick=()=>choose(c.tp); g.appendChild(b);
  });
}

function choose(tp){
  G.route[tp]++; G.globalRoute[tp]++;
  if(tp==='g'){ G.psy=Math.min(100,G.psy+8); G.spec=Math.max(0,G.spec-10); }
  else if(tp==='b'){ G.psy=Math.max(0,G.psy-10); G.spec=Math.min(100,G.spec+6); }
  else { G.spec=Math.min(100,G.spec+12); G.secretCount++; }
  updPsy(); updSpec();
  document.getElementById('chArea').style.display='none';
  document.getElementById('dlgArea').style.display='none';
  if(G.handsDone>=G.totalHands) setTimeout(endBattle,400);
  else showCtrl(false,false,true);
}

/* ============================================================
   FIM DE BATALHA
   ============================================================ */
function getRouteFor(r){ if(r.s>=2) return 's'; if(r.g>r.b) return 'g'; return 'b'; }

function endBattle(){
  const rt = getRouteFor(G.route);
  const isDealer = G.currentEnemy === DEALER;
  const en = G.currentEnemy;
  G.savedRoutes[en.id||'dealer'] = rt;

  if(!isDealer){
    const items = en.items||{};
    const itm = items[rt]||items.g;
    G.lastItemEarned = itm ? itm.name : null;
    G.gold += 2;
    const bk = G.bookUnlocks[en.id]||{};
    bk[rt]=true; if(rt==='g'||rt==='b') bk.both=true;
    G.bookUnlocks[en.id]=bk;
    G.curEnemy++;
    goMap();
  } else {
    G.campaignDone=true;
    G.bookUnlocks['dealer']={};
    G.bookUnlocks['dealer'][rt]=true;
    if(rt==='g'||rt==='b') G.bookUnlocks['dealer'].both=true;
    showEnd(rt);
  }
}

/* ============================================================
   TELA FINAL
   ============================================================ */
function showEnd(rt){
  const finals = {
    g:{ orn:'♥ ♥ ♥', title:'O ciclo foi interrompido', badge:'Caminho da redenção', tc:'#4aaa6a',
        txt:'Não é um final feliz. É um final honesto. Algumas cicatrizes fecharam. Outras ainda sangram. Mas o cassino, por uma noite, não lucrou com o desespero de ninguém.',
        itemN:'Carta final — carta branca', itemD:'O Dealer entregou uma carta em branco. Não estava escrita. Talvez fosse só papel. Talvez fosse tudo.' },
    b:{ orn:'♠ ♠ ♠', title:'O ciclo continua', badge:'Caminho da corrupção', tc:'#aa3a3a',
        txt:'O Dealer deixou uma carta na mesa e foi embora. Não era de despedida — era de transferência. O cassino tem um novo rosto. O seu.',
        itemN:'Carta final — tinta vermelha', itemD:'O nome do protagonista estava escrito nela. Com a caligrafia do Dealer.' },
    s:{ orn:'♦ ♦ ♦', title:'O protagonista se tornou o sistema', badge:'Final secreto', tc:'#8a5ab8',
        txt:'O Dealer se recusou a jogar a quarta rodada. Disse apenas: "Você já chegou onde precisava chegar." O protagonista está sentado à mesa com os outros.',
        itemN:'Carta final — sem nome', itemD:'A carta está em branco nos dois lados. O Vendedor disse que isso nunca tinha acontecido antes.' }
  };
  const f = finals[rt]||finals.g;
  document.getElementById('eOrn').textContent=f.orn;
  document.getElementById('eTitle').textContent=f.title;
  const b=document.getElementById('eBadge'); b.textContent=f.badge; b.style.color=f.tc; b.style.borderColor=f.tc;
  document.getElementById('eTxt').textContent=f.txt;
  document.getElementById('eSW').textContent=G.globalRoute.g;
  document.getElementById('eSC').textContent=G.globalRoute.b;
  document.getElementById('eSS').textContent=G.globalRoute.s;
  document.getElementById('eItemN').textContent=f.itemN;
  document.getElementById('eItemD').textContent=f.itemD;
  const em=document.getElementById('eMap'); em.innerHTML='';
  [...ENEMIES,DEALER].forEach(e=>{
    const id=e.id||'dealer';
    const r=G.savedRoutes[id];
    const col=r==='g'?'#4aaa6a':r==='b'?'#aa3a3a':r==='s'?'#8a5ab8':e.col+'44';
    const sym=r==='g'?'♥':r==='b'?'♠':r==='s'?'♦':'?';
    const nd=document.createElement('div'); nd.className='e-mn';
    nd.innerHTML=`<div class="e-mico" style="color:${col}">${e.icon}</div><div style="color:${col};font-size:9px;margin-top:2px">${sym}</div><div style="color:#3a2a4a;font-size:9px">${e.name||'Dealer'}</div>`;
    em.appendChild(nd);
  });
  show('sE');
}

/* ============================================================
   LIVRO DE MEMÓRIAS
   ============================================================ */
function renderBook(){
  const grid=document.getElementById('bkGrid');
  document.getElementById('bkEntry').style.display='none';
  grid.style.display='';
  grid.innerHTML='';
  Object.entries(BOOK_ENTRIES).forEach(([id,e])=>{
    const unlocked=G.bookUnlocks[id]&&Object.keys(G.bookUnlocks[id]).length>0;
    const enData=ENEMIES.find(x=>x.id===id);
    const col=enData?enData.col:DEALER.col;
    const card=document.createElement('div');
    card.className='bk-card'+(unlocked?'':' locked');
    card.innerHTML=`<div class="bk-cicon" style="color:${unlocked?col:'#2a1a3a'}">${e.icon}</div><div class="bk-cname" style="color:${unlocked?'#c0a8d8':'#2a1a3a'}">${e.name}</div><div class="bk-csub" style="color:${unlocked?'#5a4a6a':'#1a1428'}">${e.sub}</div>`;
    if(unlocked) card.onclick=()=>openEntry(id,e,col);
    grid.appendChild(card);
  });
}

function openEntry(id,e,col){
  document.getElementById('bkGrid').style.display='none';
  const entry=document.getElementById('bkEntry'); entry.style.display='block';
  document.getElementById('bkEName').textContent=e.name; document.getElementById('bkEName').style.color=col;
  document.getElementById('bkESub').textContent=e.sub;
  const cont=document.getElementById('bkEContent'); cont.innerHTML='';
  const unlocks=G.bookUnlocks[id]||{};
  e.sections.forEach(sec=>{
    const avail=!sec.unlocked||(sec.unlocked==='g'&&unlocks.g)||(sec.unlocked==='b'&&unlocks.b)||(sec.unlocked==='s'&&unlocks.s)||(sec.unlocked==='both'&&unlocks.both);
    const div=document.createElement('div'); div.className='bk-sec';
    if(avail){
      div.innerHTML=`<div class="bk-sec-lbl" style="color:${col}88;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px">${sec.lbl}</div><div class="bk-sec-txt" style="color:#8a7a9a">${sec.txt}</div>`;
    } else {
      div.innerHTML=`<div class="bk-sec-lbl" style="color:#2a1a3a;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px">${sec.lbl}</div><div class="bk-sec-txt" style="color:#1e1828;font-style:italic">[ Desbloqueado ao explorar este caminho ]</div>`;
    }
    cont.appendChild(div);
  });
}

/* ============================================================
   INIT
   ============================================================ */
renderTit();
</script>
